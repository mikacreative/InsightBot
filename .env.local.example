## ============================================================
## InsightBot 本地测试环境变量模板
## 使用方法: cp .env.local.example .env.local  然后填写真实值
## .env.local 已在 .gitignore 中忽略，不会被提交到仓库
## ============================================================

## --- 运行路径（本地测试专用，指向项目根目录）---
MARKETING_BOT_DIR=./
CONFIG_CONTENT_FILE=./config.local.content.json
CONFIG_SECRETS_FILE=./config.local.secrets.json
LOGS_DIR=./logs_local
LOG_FILE=./logs_local/cron.log
BOT_LOG_FILE=./logs_local/bot.log
DAILY_LOG_FILE=./logs_local/daily_brief.log
SMART_BRIEF_PATH=./smart_brief.py
PYTHON_BIN=python3

## --- 企业微信（使用测试专用应用，避免污染生产群组）---
## 建议在企业微信后台创建一个名为"InsightBot测试"的自建应用
WECOM_CID=your_test_corpid_here
WECOM_SECRET=your_test_app_secret_here
WECOM_AID=your_test_agent_id_here

## --- LLM 配置（可使用低成本模型进行测试）---
AI_API_KEY=your_api_key_here
AI_API_URL=https://api.deepseek.com/v1/chat/completions
AI_MODEL=deepseek-chat

## --- 测试专用开关 ---
## 设为 1 时，bot 完整运行但最后不推送企业微信，改为输出到本地文件
DRY_RUN=1
## dry_run 模式下报告的输出路径
DRY_RUN_OUTPUT=./logs_local/dry_run_report.md
