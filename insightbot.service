[Unit]
Description=InsightBot Streamlit App
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/marketing_bot
ExecStart=/root/marketing_bot/.venv/bin/python -m streamlit run /root/marketing_bot/scripts/app.py --server.port 8501 --server.headless=true
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
