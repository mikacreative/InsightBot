## --- Runtime paths (optional) ---
# If you deploy under /root/marketing_bot you can omit these.
MARKETING_BOT_DIR=/root/marketing_bot
# CONFIG_FILE=/root/marketing_bot/config.json
# LOGS_DIR=/root/marketing_bot/logs
# LOG_FILE=/root/marketing_bot/logs/cron.log
# BOT_LOG_FILE=/root/marketing_bot/logs/bot.log
# DAILY_LOG_FILE=/root/marketing_bot/logs/daily_brief.log
# SMART_BRIEF_PATH=/root/marketing_bot/smart_brief.py
# PYTHON_BIN=/usr/bin/python3

## --- WeCom (required for sending) ---
WECOM_CID=
WECOM_SECRET=
WECOM_AID=

## --- LLM (required for summaries) ---
AI_API_KEY=
AI_API_URL=
AI_MODEL=
